# ====== Shared ======
NODE_ENV=development
APP_DOMAIN=laborparfum.com
PUBLIC_URL=http://localhost:3001

# ====== Postgres ======
POSTGRES_DB=labor_dev
POSTGRES_USER=labor
POSTGRES_PASSWORD=REPLACE_ME_POSTGRES_PASSWORD # REQUIRED — fail-fast at boot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://labor:REPLACE_ME_POSTGRES_PASSWORD@postgres:5432/labor_dev # REQUIRED — fail-fast at boot

# ====== Redis ======
REDIS_URL=redis://redis:6379/0

# ====== Rails (apps/backend) ======
RAILS_ENV=development
SECRET_KEY_BASE=REPLACE_ME_SECRET_KEY_BASE # REQUIRED — fail-fast at boot (generate with: bundle exec rails secret)
RAILS_MASTER_KEY= # Optional — only needed if using encrypted credentials
BACKEND_PORT=3000
BACKEND_INTERNAL_URL=http://backend:3000
BACKEND_PUBLIC_URL=https://laborparfum.com/api
CORS_ORIGINS=https://laborparfum.com # comma-separated; defaults to localhost:3001 — MUST set in prod or browser calls are CORS-blocked
PUBLIC_HOST=https://laborparfum.com # REQUIRED in prod — base URL for Active Storage blob URLs in API responses; defaults to http://localhost:4000 which breaks images on any non-local host

# ====== Next.js (apps/web) ======
WEB_PORT=3001
NEXT_PUBLIC_APP_URL=https://laborparfum.com
NEXT_PUBLIC_API_URL=https://laborparfum.com/api
INTERNAL_API_URL=http://backend:3000

# ====== Analytics & Observability ======
# ALL OPTIONAL. Each integration is env-gated: a blank value means the feature
# is simply off (track() no-ops, Sentry.init never runs). None are in
# REQUIRED_ENV_KEYS — observability/analytics is not a security secret, so a
# missing value must mean "feature off," never "app won't boot."
#
# Analytics pixels (apps/web) — load only on the (site) storefront, never /tg/.
NEXT_PUBLIC_GA_MEASUREMENT_ID= # Optional — GA4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=     # Optional — Meta (Facebook) Pixel ID, numeric
#
# Sentry error monitoring.
NEXT_PUBLIC_SENTRY_DSN= # Optional — web DSN (browser-shipped, public by design)
SENTRY_DSN=             # Optional — Rails + Sidekiq DSN (apps/backend)
# Build-only, for source-map upload (skipped if absent — build still succeeds):
SENTRY_ORG=         # Optional — Sentry org slug
SENTRY_PROJECT=     # Optional — Sentry project slug
SENTRY_AUTH_TOKEN=  # Optional — build-time only; never shipped to the browser

# ====== Telegram ======
TELEGRAM_BOT_TOKEN=REPLACE_ME_TELEGRAM_BOT_TOKEN # REQUIRED — fail-fast at boot (bot)
TELEGRAM_BOT_USERNAME=labor_uz_bot
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_TELEGRAM_WEBHOOK_SECRET_MIN_16_CHARS # REQUIRED — fail-fast at boot (min 16 chars)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=labor_uz_bot
NEXT_PUBLIC_MINIAPP_URL=https://laborparfum.com/tg

# ====== Payments ======
# Click
CLICK_SERVICE_ID=REPLACE_ME_CLICK_SERVICE_ID # REQUIRED in production — fail-fast at boot
CLICK_MERCHANT_ID=REPLACE_ME_CLICK_MERCHANT_ID # REQUIRED in production
CLICK_SECRET_KEY=REPLACE_ME_CLICK_SECRET_KEY # REQUIRED — fail-fast at boot (HMAC key for webhooks)
CLICK_MERCHANT_USER_ID=REPLACE_ME_CLICK_MERCHANT_USER_ID # REQUIRED in production

# Payme
PAYME_MERCHANT_ID=REPLACE_ME_PAYME_MERCHANT_ID # REQUIRED in production
PAYME_KEY_TEST=REPLACE_ME_PAYME_KEY_TEST # REQUIRED in test/dev
PAYME_KEY_PROD=REPLACE_ME_PAYME_KEY_PROD # REQUIRED in production
PAYME_MERCHANT_KEY=REPLACE_ME_PAYME_MERCHANT_KEY # REQUIRED — fail-fast at boot
PAYME_ENV=test

# Uzum Bank
UZUM_MERCHANT_ID=REPLACE_ME_UZUM_MERCHANT_ID # REQUIRED in production
UZUM_API_KEY=REPLACE_ME_UZUM_API_KEY # REQUIRED in production
UZUM_API_SECRET=REPLACE_ME_UZUM_API_SECRET # REQUIRED in production

# ====== Delivery ======
YANDEX_DELIVERY_OAUTH_TOKEN=REPLACE_ME_YANDEX_DELIVERY_OAUTH_TOKEN # REQUIRED in production
YANDEX_DELIVERY_API_URL=https://b2b.taxi.yandex.net
EXPRESS24_API_KEY=REPLACE_ME_EXPRESS24_API_KEY # REQUIRED in production
EXPRESS24_API_URL=https://app.express24.uz/api

# ====== Express24 webhooks ======
EXPRESS24_WEBHOOK_SECRET=REPLACE_ME_EXPRESS24_WEBHOOK_SECRET # REQUIRED in production

# ====== Warehouse (origin for Yandex Delivery pickups) ======
LABOR_WAREHOUSE_LON=69.279737
LABOR_WAREHOUSE_LAT=41.311081
LABOR_WAREHOUSE_ADDRESS=Tashkent, Amir Temur ave., 1
LABOR_WAREHOUSE_CONTACT=Labor Warehouse
LABOR_WAREHOUSE_PHONE=+998900000000

# ====== Bot <-> backend bridge ======
BOT_INTERNAL_URL=http://bot:8080
INTERNAL_NOTIFY_TOKEN=REPLACE_ME_INTERNAL_NOTIFY_TOKEN_MIN_32_CHARS # REQUIRED — fail-fast at boot (min 32 chars, HMAC key)
WEBAPP_URL=https://laborparfum.com
TELEGRAM_ADMIN_CHAT_ID=
# Target channel/chat for Labor::Campaign broadcasts (e.g. -1001234567890)
TELEGRAM_CHANNEL_CHAT_ID=

# ====== Fiscal (v2 OFD integration; v1 manual) ======
FISCAL_PROVIDER=manual

# ====== Active Storage service selector ======
# `local` for dev (Disk service, stores under apps/backend/storage/).
# `amazon` for production (S3 via aws-sdk-s3, see S3_* below).
STORAGE_SERVICE=local

# ====== S3 / S3-compatible storage ======
# Leave S3_ENDPOINT blank for AWS S3. Set it to e.g. https://hb.bizmrg.com
# or a MinIO URL for S3-compatible providers, and flip S3_FORCE_PATH_STYLE=true
# when the provider requires path-style addressing.
S3_REGION=us-east-1
S3_BUCKET=labor-uploads
S3_ACCESS_KEY_ID=REPLACE_ME_S3_ACCESS_KEY_ID # REQUIRED if STORAGE_SERVICE=amazon
S3_SECRET_ACCESS_KEY=REPLACE_ME_S3_SECRET_ACCESS_KEY # REQUIRED if STORAGE_SERVICE=amazon
S3_ENDPOINT= # Optional — only set for S3-compatible (non-AWS) providers
S3_FORCE_PATH_STYLE=false # Optional — set 'true' for MinIO / some S3-compat endpoints

# ====== CDN (optional) ======
# CloudFront / generic CDN host for Propshaft assets + Active Storage URLs.
# Must forward signed query params untouched, otherwise private blob URLs 403.
CDN_BASE_URL= # Optional — e.g. https://cdn.laborparfum.com
