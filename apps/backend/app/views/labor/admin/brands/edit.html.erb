<% admin_breadcrumb('Brands', spree.admin_labor_brands_path) %>
<% admin_breadcrumb(@brand.name) %>

<% content_for :page_title do %>
  Edit Brand: <%= @brand.name %>
<% end %>

<%= form_with model: @brand,
              url: spree.admin_labor_brand_path(@brand),
              method: :patch,
              local: true,
              html: { class: 'edit_labor_brand' } do |f| %>
  <%= render 'form', f: f %>
<% end %>
