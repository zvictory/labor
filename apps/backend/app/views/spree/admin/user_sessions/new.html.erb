<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Labor Admin Login</title>
  <%= csrf_meta_tags %>
  <style>
    body { margin: 0; background: #f3f4f6; font-family: system-ui, sans-serif; }
    .login-form { max-width: 360px; margin: 80px auto; padding: 32px; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; }
    .login-form h1 { font-size: 22px; margin: 0 0 24px; text-align: center; }
    .field { margin-bottom: 16px; }
    .field label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; color: #6b7280; }
    .field input { width: 100%; padding: 10px; border: 1px solid #d1d5db; border-radius: 4px; font-size: 14px; box-sizing: border-box; }
    .submit { width: 100%; padding: 12px; background: #111827; color: #fff; border: 0; border-radius: 4px; font-size: 14px; cursor: pointer; }
    .alert { background: #fef2f2; color: #991b1b; padding: 12px; margin-bottom: 16px; border-radius: 4px; font-size: 14px; }
  </style>
</head>
<body>
  <div class="login-form">
    <h1>Labor Admin</h1>

    <% if flash[:error].present? %>
      <div class="alert"><%= flash[:error] %></div>
    <% end %>

    <%= form_with url: spree.admin_login_path, scope: :spree_user, local: true do |f| %>
      <div class="field">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, required: true %>
      </div>
      <div class="field" style="margin-bottom: 24px;">
        <%= f.label :password %>
        <%= f.password_field :password, required: true %>
      </div>
      <%= f.submit 'Sign in', class: 'submit' %>
    <% end %>
  </div>
</body>
</html>
