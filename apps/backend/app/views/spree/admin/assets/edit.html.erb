<%# Labor override of spree_admin-5.4.3/app/views/spree/admin/assets/edit.html.erb.
    Replaces the Turbo-confirm `link_to` Delete with an inline button_to so the
    delete fires on first click. Spree's custom turbo_confirm dialog requires
    `#turbo-confirm-dialog` in the DOM; when absent the link silently no-ops
    after the native window.confirm is cancelled or blocked. %>
<%= turbo_frame_tag :dialog do %>
  <%= dialog_header(Spree.t(:edit) + ' ' + Spree.t(:image)) %>
  <%= form_with model: @asset, url: spree.admin_asset_path(@asset), method: :put, scope: :asset do |f| %>
    <div class="dialog-body pb-0" data-turbo-permanent id="asset-<%= @asset.key.parameterize %>">
      <%= f.spree_file_field :attachment, width: 200, height: 200, can_delete: false, label: Spree.t(:image) %>
    </div>
    <div class="dialog-body" style="min-height: 200px">
      <%= f.spree_text_area :alt, label: Spree.t(:alt_text), rows: 4 %>
    </div>
    <div class="dialog-footer">
      <%= turbo_save_button_tag %>
      <% if can?(:destroy, @asset) %>
        <%= button_to Spree.t('actions.destroy'),
            spree.admin_asset_path(@asset),
            method: :delete,
            form: { data: { turbo_frame: '_top' }, style: 'margin-left:auto' },
            class: 'btn btn-danger' %>
      <% end %>
    </div>
  <% end %>
<% end %>
